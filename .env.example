# Firebase Configuration (Web)
# Copia este archivo a `.env` y completa con los valores de tu proyecto Firebase.
# Encontrarás estos valores en: Firebase Console > Configuración del proyecto > Tus apps (Web).
# Solo se exponen las variables con prefijo VITE_ al navegador.

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
