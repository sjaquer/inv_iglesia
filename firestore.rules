rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /products/{productId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['code', 'name', 'category', 'stock', 'createdAt'])
                    && request.resource.data.stock is number
                    && request.resource.data.stock >= 0;
      allow update: if request.resource.data.stock is number
                    && request.resource.data.stock >= 0;
      allow delete: if false; // No permitir borrar para mantener la integridad
    }
    
    match /transactions/{transactionId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['productId', 'type', 'quantity', 'date', 'personName', 'createdAt'])
                    && request.resource.data.quantity is number
                    && request.resource.data.quantity > 0
                    && (request.resource.data.type == 'IN' || request.resource.data.type == 'OUT' || request.resource.data.type == 'RETURN');
      allow update, delete: if false; // Las transacciones son inmutables
    }

    match /workers/{workerId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['name', 'role', 'createdAt']);
      allow update, delete: if true;
    }

    match /schedules/{scheduleId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll(['workerId', 'date', 'startTime', 'endTime', 'location', 'createdAt']);
      allow update, delete: if true;
    }
  }
}
